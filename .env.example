# Phase 1 - Qwen API (Required for all components)
QWEN_API_URL=https://qwen.aikit.club/v1/chat/completions
QWEN_TOKEN=your_token_here

# Phase 2 - Agent HTTP Server
PORT=3000
AGENT_TIMEOUT=15

# Phase 2 - Discord Relay Bot
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id
AGENT_API_URL=http://localhost:3000
HUMAN_USERNAMES=username1,username2,username3

# Optional - Pre-created webhook URLs (if not creating at runtime)
# WEBHOOK_KIARA=https://discord.com/api/webhooks/...
# etc.